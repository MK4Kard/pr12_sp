<Page x:Class="pr12_vUser.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:converters="clr-namespace:pr12_vUser.Converters"
      xmlns:local="clr-namespace:pr12_vUser.Pages"   
      xmlns:datas="clr-namespace:pr12_vUser.Data"
      xmlns:services="clr-namespace:pr12_vUser.Services"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      DataContext="{Binding RelativeSource={RelativeSource Self}}"
      Title="MainPage">
    <Page.Resources>
        <converters:DateConverter x:Key="dateConventer"/>
        <converters:ImageConverter x:Key="imageConventer"/>
        <services:InterestGroupService x:Key="rService"/>
        <services:UserInterestGroupService x:Key="ugService"/>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" Grid.ColumnSpan="2">
            <Button Click="go_form">Добавить</Button>
            <Button Click="remove">Удалить</Button>
            <Button Click="roles">Роли</Button>
            <Button Click="groups">Группы</Button>
            <Button Click="userToGroup">Вступить в группу</Button>
        </StackPanel>
        <ListView Grid.Row="1"
                  ItemsSource="{Binding service.Users}"
                  MouseDoubleClick="Edit"
                  SelectedItem="{Binding user}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition MinWidth="180"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Stretch="UniformToFill"
                               Margin="10" Width="120">
                            <Image.Source>
                                <Binding Path="UserProfile.AvatarUrl"
                                         Converter="{StaticResource imageConventer}">
                                    <Binding.TargetNullValue>
                                        <ImageSource>C:\Users\DNS\OneDrive\Рабочий стол\Доделывать\pr12_trpo_orig\no-image.jpg</ImageSource>
                                    </Binding.TargetNullValue>
                                </Binding>
                            </Image.Source>
                        </Image>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Login}" Foreground="Black"/>
                            <TextBlock Text="{Binding Name}" Foreground="Black"/>
                            <TextBlock Text="{Binding Email}" Foreground="Black"/>
                            <TextBlock Text="{Binding Password}" Foreground="Black"/>
                            <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}" Foreground="Black"/>
                            <TextBlock Foreground="Black">
                                <Run Text="Роль: "/>
                                <Run Text="{Binding Role.Title}"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Foreground="Black">
                                <Run Text="Номер телефона: "/>
                                <Run Text="{Binding UserProfile.Phone}"/>
                            </TextBlock>
                            <TextBlock Foreground="Black">
                                <Run Text="Дата рождения: "/>
                                <Run Text="{Binding UserProfile.Birthday, Converter={StaticResource dateConventer}, StringFormat={}{0:dd.MM.yyyy}}"/>
                            </TextBlock>
                            <TextBlock Foreground="Black">
                                <Run Text="Краткое описание: "/>
                                <Run Text="{Binding UserProfile.Bio}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <ListView Grid.Row="1" Grid.Column="1"
                  ItemsSource="{Binding user.UserInterestGroups}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock>
                            <Run Text="Группа:" Foreground="Black"/>
                            <Run Text="{Binding InterestGroup.Title}" Foreground="Black"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Вступил" Foreground="Black"/>
                            <Run Text="{Binding JoinedAt, StringFormat={}{0:dd.MM.yyyy}}" Foreground="Black"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Модератор -" Foreground="Black"/>
                            <Run Text="{Binding IsModerator}" Foreground="Black"/>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
