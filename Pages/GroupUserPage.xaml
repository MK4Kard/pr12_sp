<Page x:Class="pr12_vUser.Pages.GroupUserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:m="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:pr12_vUser.Pages"
      xmlns:validators="clr-namespace:pr12_vUser.ValidationRules"
      xmlns:converters="clr-namespace:pr12_vUser.Converters"
      xmlns:services="clr-namespace:pr12_vUser.Services"
      xmlns:datas="clr-namespace:pr12_vUser.Data"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      DataContext="{Binding RelativeSource={RelativeSource Self}}"
      Title="GroupUserPage">
    <Page.Resources>
        <converters:InverseAndBooleansToBooleanConverter x:Key="boolConverter"/>
        <converters:DateConverter x:Key="dateConventer"/>
        <services:InterestGroupService x:Key="rService"/>
        <services:UserInterestGroupService x:Key="uiService"/>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <Button Click="back">Назад</Button>
        </StackPanel>
        <StackPanel Grid.Row="1">
            <StackPanel DataContext="{Binding user}">
                <Label Content="Информация о пользователе" FontSize="20"/>
                <TextBlock Text="{Binding Login}" Style="{StaticResource Marg}"/>
                <TextBlock Text="{Binding Name}" Style="{StaticResource Marg}"/>
                <TextBlock Text="{Binding Email}" Style="{StaticResource Marg}"/>
                <TextBlock Text="{Binding Role.Title}" Style="{StaticResource Marg}"/>
                <TextBlock Text="Дата вступления" Style="{StaticResource Marg}"/>
            </StackPanel>
            <StackPanel>
                <DatePicker x:Name="date" DisplayDateStart="1970.01.01" DisplayDateEnd="2026.04.30"
                                    m:HintAssist.Hint="Выберите дату">
                    <DatePicker.SelectedDate>
                        <Binding Path="dateJoin" UpdateSourceTrigger="PropertyChanged"
                                Converter="{StaticResource dateConventer}">
                            <Binding.ValidationRules>
                                <validators:DateValidation 
                                    ValidatesOnTargetUpdated="True"/>
                            </Binding.ValidationRules>
                        </Binding>
                    </DatePicker.SelectedDate>
                </DatePicker>
                <CheckBox Content="Модератор"  Margin="5 15 5 0" Padding="0"
                          IsChecked="{Binding moderator}" Cursor=""/>
            </StackPanel>
            <Button Click="add" Content="Записать в группу">
                <Button.IsEnabled>
                    <MultiBinding Converter="{StaticResource boolConverter}">
                        <Binding ElementName="date" Path="(Validation.HasError)"/>
                    </MultiBinding>
                </Button.IsEnabled>
            </Button>
        </StackPanel>
        <ListView Grid.RowSpan="2" Grid.Column="1"
                  x:Name="list"
                  ItemsSource="{Binding Source={StaticResource rService}, Path=InterestGroups}"
                  SelectionMode="Multiple"
                  Foreground="#FF9DFF50">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock Foreground="Black" Text="{Binding Title}"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
